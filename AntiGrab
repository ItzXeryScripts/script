local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local Debris = game:GetService("Debris")

local GrabEvents = ReplicatedStorage:WaitForChild("GrabEvents", 10)
local MenuToys = ReplicatedStorage:WaitForChild("MenuToys", 10)
local CharacterEvents = ReplicatedStorage:WaitForChild("CharacterEvents", 10)
local SetNetworkOwner = GrabEvents:WaitForChild("SetNetworkOwner")
local Struggle = CharacterEvents:WaitForChild("Struggle")
local DestroyToy = MenuToys:WaitForChild("DestroyToy")

local localPlayer = Players.LocalPlayer

local g = getgenv()
g.anchoredParts = g.anchoredParts or {}
g.anchoredConnections = g.anchoredConnections or {}
g.connections = g.connections or {}
g.kickGrabConnections = g.kickGrabConnections or {}
g.poisonHurtParts = g.poisonHurtParts or {}
g.paintPlayerParts = g.paintPlayerParts or {}

g.AntiGrabState = g.AntiGrabState or false
g.AntiGrabLocked = g.AntiGrabLocked or false
if g.AntiGrabConn then g.AntiGrabConn:Disconnect(); g.AntiGrabConn = nil end

local COLOR_ON = Color3.fromRGB(80, 255, 80)
local COLOR_OFF = Color3.fromRGB(255, 80, 80)
local ICON_LOCK = "rbxassetid://187897035"
local ICON_UNLOCK = "rbxassetid://187897042"

local CG = (pcall(function() return game:GetService("CoreGui") end) and game:GetService("CoreGui")) or localPlayer:WaitForChild("PlayerGui")
if CG:FindFirstChild("AntiGrabUI") then CG.AntiGrabUI:Destroy() end

local SG = Instance.new("ScreenGui", CG)
SG.Name = "AntiGrabUI"
SG.ResetOnSpawn = false

local MainFrame = Instance.new("Frame", SG)
MainFrame.Size = UDim2.new(0, 140, 0, 35)
MainFrame.Position = UDim2.new(0.5, -70, 0.1, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.BorderSizePixel = 0
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 8)

local MainStroke = Instance.new("UIStroke", MainFrame)
MainStroke.Thickness = 1.5

local MainText = Instance.new("TextLabel", MainFrame)
MainText.Size = UDim2.new(1, 0, 1, 0)
MainText.BackgroundTransparency = 1
MainText.Text = "AntiGrab"
MainText.Font = Enum.Font.GothamBold
MainText.TextSize = 16

local LockFrame = Instance.new("Frame", MainFrame)
LockFrame.Size = UDim2.new(0, 24, 0, 24)
LockFrame.Position = UDim2.new(1, -12, 0, -12)
LockFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
LockFrame.BorderSizePixel = 0
Instance.new("UICorner", LockFrame).CornerRadius = UDim.new(0, 6)

local LockStroke = Instance.new("UIStroke", LockFrame)
LockStroke.Thickness = 1.5

local LockIcon = Instance.new("ImageLabel", LockFrame)
LockIcon.Size = UDim2.new(0.65, 0, 0.65, 0)
LockIcon.Position = UDim2.new(0.175, 0, 0.175, 0)
LockIcon.BackgroundTransparency = 1
LockIcon.ScaleType = Enum.ScaleType.Fit

local function UpdateLock()
    LockIcon.Image = g.AntiGrabLocked and ICON_LOCK or ICON_UNLOCK
    LockStroke.Color = g.AntiGrabLocked and COLOR_ON or COLOR_OFF
end

local function UpdateAntiGrab()
    local color = g.AntiGrabState and COLOR_ON or COLOR_OFF
    MainText.TextColor3 = color
    MainStroke.Color = color

    if g.AntiGrabConn then g.AntiGrabConn:Disconnect(); g.AntiGrabConn = nil end
    if g.AntiGrabState then
        g.AntiGrabConn = RunService.Heartbeat:Connect(function()
            pcall(function()
                local char = localPlayer.Character
                if char and localPlayer.IsHeld and localPlayer.IsHeld.Value then
                    Struggle:FireServer()
                    for _, v in pairs(char:GetChildren()) do if v:IsA("BasePart") then v.Anchored = true end end
                    task.wait(0.1)
                    for _, v in pairs(char:GetChildren()) do if v:IsA("BasePart") then v.Anchored = false end end
                end
            end)
        end)
    end
end

UpdateLock()
UpdateAntiGrab()

local dragging, dragStart, startPos = false, nil, nil

LockFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        g.AntiGrabLocked = not g.AntiGrabLocked
        UpdateLock()
    end
end)

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging, dragStart, startPos = true, input.Position, MainFrame.Position
        
        local conn; conn = input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false; conn:Disconnect()
                if (input.Position - dragStart).Magnitude < 5 then
                    g.AntiGrabState = not g.AntiGrabState
                    UpdateAntiGrab()
                end
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and not g.AntiGrabLocked and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
